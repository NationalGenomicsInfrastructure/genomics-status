{
    "name": "Genomics Status - Dev (Local DB)",
    "dockerComposeFile": "../../docker-compose.yml",
    "service": "genomics-status",
    "workspaceFolder": "/app",

    "initializeCommand": "bash -c 'echo \"Stopping any running docker-compose services...\" && docker-compose down 2>/dev/null || true && if [ ! -d ../StatusDB_seed_data ]; then echo \"Cloning StatusDB_seed_data...\"; git clone https://github.com/SciLifeLab/StatusDB_seed_data.git ../StatusDB_seed_data; else echo \"StatusDB_seed_data already exists\"; fi'",
    "onCreateCommand": "./.devcontainer/dev/onCreateCommand.sh",
    "features": {},

    "customizations": {
        "vscode": {
            "extensions": [
                "charliermarsh.ruff",
                "ms-python.python",
                "Tobermory.es6-string-html"
            ]
        }
    },

    "forwardPorts": [9761, 5984],
    "portsAttributes": {
        "9761": {
            "label": "Genomics Status",
            "onAutoForward": "notify"
        },
        "5984": {
            "label": "CouchDB",
            "onAutoForward": "silent"
        }
    },

    "postCreateCommand": "./.devcontainer/dev/postCreateCommand.sh",
    "postStartCommand": "cd run_dir && python ../status_app.py --develop --testing_mode",

    "remoteUser": "mambauser"
}
