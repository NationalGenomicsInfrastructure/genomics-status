{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genomics-status.scilifelab.se/schemas/sample_classification_patterns.schema.json",
  "title": "Sample Classification Patterns Configuration",
  "description": "Configuration schema for demultiplexing sample classification patterns, library method mappings, and UMI configurations",
  "type": "object",
"required": [
    "patterns",
    "other_general_sample_types",
    "control_patterns",
    "short_single_index_threshold"
],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to the JSON schema for validation"
    },
    "patterns": {
      "type": "object",
      "description": "Dictionary of sample classification patterns with regex matching and configuration",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "object",
          "properties": {
            "regex": {
              "type": "string",
              "description": "Regular expression pattern to match sample indices or identifiers"
            },
            "description": {
              "$ref": "#/$defs/sampleConfig/properties/description"
            },
            "sample_type": {
              "$ref": "#/$defs/sampleConfig/properties/sample_type"
            },
            "index_length": {
              "$ref": "#/$defs/sampleConfig/properties/index_length"
            },
            "umi_config": {
              "$ref": "#/$defs/sampleConfig/properties/umi_config"
            },
            "calculate_lengths": {
              "$ref": "#/$defs/sampleConfig/properties/calculate_lengths"
            },
            "named_indices": {
              "$ref": "#/$defs/sampleConfig/properties/named_indices"
            },
            "BCLConvert_Settings": {
                "$ref": "#/$defs/sampleConfig/properties/BCLConvert_Settings"
            },
            "conditional_rules": {
                "$ref": "#/$defs/sampleConfig/properties/conditional_rules"
            }
        },
        "additionalProperties": false
    }
},
"additionalProperties": false
},
"other_general_sample_types": {
"type": "object",
"description": "General sample type configurations that don't use regex pattern matching",
"patternProperties": {
    "^[a-z_]+$": {
        "type": "object",
        "required": [
            "description",
            "sample_type"
        ],
        "properties": {
            "description": {
                "$ref": "#/$defs/sampleConfig/properties/description"
            },
            "sample_type": {
                "$ref": "#/$defs/sampleConfig/properties/sample_type"
            },
            "index_length": {
                "$ref": "#/$defs/sampleConfig/properties/index_length"
            },
            "umi_config": {
                "$ref": "#/$defs/sampleConfig/properties/umi_config"
            },
            "calculate_lengths": {
                "$ref": "#/$defs/sampleConfig/properties/calculate_lengths"
            },
            "named_indices": {
                "$ref": "#/$defs/sampleConfig/properties/named_indices"
            },
            "BCLConvert_Settings": {
                "$ref": "#/$defs/sampleConfig/properties/BCLConvert_Settings"
            },
            "conditional_rules": {
                "$ref": "#/$defs/sampleConfig/properties/conditional_rules"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "library_method_mapping": {
      "type": "object",
      "description": "Mapping of library preparation methods to their sample type configurations",
      "patternProperties": {
        ".*": {
          "type": "object",
          "required": ["sample_type"],
          "properties": {
            "description": {
              "$ref": "#/$defs/sampleConfig/properties/description"
            },
            "sample_type": {
              "$ref": "#/$defs/sampleConfig/properties/sample_type"
            },
            "index_length": {
              "$ref": "#/$defs/sampleConfig/properties/index_length"
            },
            "umi_config": {
              "$ref": "#/$defs/sampleConfig/properties/umi_config"
            },
            "calculate_lengths": {
              "$ref": "#/$defs/sampleConfig/properties/calculate_lengths"
            },
            "named_indices": {
              "$ref": "#/$defs/sampleConfig/properties/named_indices"
            },
            "BCLConvert_Settings": {
                "$ref": "#/$defs/sampleConfig/properties/BCLConvert_Settings"
            },
            "conditional_rules": {
                "$ref": "#/$defs/sampleConfig/properties/conditional_rules"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "instrument_type_mapping": {
      "type": "object",
      "description": "Mapping of instrument types and run modes to their configurations",
      "patternProperties": {
        ".*": {
          "type": "object",
          "properties": {
            "description": {
              "$ref": "#/$defs/sampleConfig/properties/description"
            },
            "sample_type": {
              "$ref": "#/$defs/sampleConfig/properties/sample_type"
            },
            "umi_config": {
              "$ref": "#/$defs/sampleConfig/properties/umi_config"
            },
            "named_indices": {
              "$ref": "#/$defs/sampleConfig/properties/named_indices"
            },
            "BCLConvert_Settings": {
              "$ref": "#/$defs/sampleConfig/properties/BCLConvert_Settings"
            },
            "conditional_rules": {
              "$ref": "#/$defs/sampleConfig/properties/conditional_rules"
            },
            "run_modes": {
              "type": "object",
              "description": "Mapping of run modes to their configurations (inherits from instrument type)",
              "patternProperties": {
                ".*": {
                  "type": "object",
                  "properties": {
                    "description": {
                      "$ref": "#/$defs/sampleConfig/properties/description"
                    },
                    "sample_type": {
                      "$ref": "#/$defs/sampleConfig/properties/sample_type"
                    },
                    "umi_config": {
                      "$ref": "#/$defs/sampleConfig/properties/umi_config"
                    },
                    "named_indices": {
                      "$ref": "#/$defs/sampleConfig/properties/named_indices"
                    },
                    "BCLConvert_Settings": {
                      "$ref": "#/$defs/sampleConfig/properties/BCLConvert_Settings"
                    },
                    "conditional_rules": {
                      "$ref": "#/$defs/sampleConfig/properties/conditional_rules"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "control_patterns": {
      "type": "array",
      "description": "List of lowercase strings to match in sample names to identify control samples",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+$"
      },
      "uniqueItems": true
    },
    "control_conditional_rules": {
      "$ref": "#/$defs/conditionalRules",
      "description": "Conditional rules to apply to control samples identified by control_patterns"
    },
    "short_single_index_threshold": {
      "type": "integer",
      "description": "Maximum length in base pairs for a single index to be classified as 'short_single_index'",
      "minimum": 1,
      "maximum": 20
    },
    "bcl_convert_settings": {
        "type": "object",
        "description": "BCL Convert configuration settings for demultiplexing",
        "properties": {
            "per_sample_settings": {
                "type": "object",
                "description": "Per-sample field mappings for BCL Convert samplesheet",
                "patternProperties": {
                    ".*": {
                        "type": "object",
                        "properties": {
                            "source_field": {
                                "type": "string",
                                "description": "Name of the source field in the sample data"
                            },
                            "type": {
                                "type": "string",
                                "enum": [
                                    "string",
                                    "integer",
                                    "boolean"
                                ],
                                "description": "Data type of the field"
                            },
                            "regex": {
                                "type": "string",
                                "description": "Regular expression for validation"
                            },
                            "help": {
                                "type": "string",
                                "description": "Help text describing the field"
                            },
                            "mandatory": {
                                "type": "boolean",
                                "description": "Whether this field is mandatory"
                            },
                            "can_be_left_blank": {
                                "type": "boolean",
                                "description": "Whether the field can be left blank"
                            },
                            "can_be_on_BCLConvert_settings": {
                                "type": "boolean",
                                "description": "Whether this setting can be placed in the BCLConvert_Settings section instead"
                            }
                        },
                        "additionalProperties": false
                    }
                },
                "additionalProperties": false
            },
            "BCLConvert_Settings": {
                "type": "object",
                "description": "Global BCL Convert settings",
                "patternProperties": {
                    ".*": {
                        "type": "object",
                        "properties": {
                            "type": {
                                "type": "string",
                                "enum": [
                                    "string",
                                    "integer",
                                    "boolean"
                                ],
                                "description": "Data type of the setting"
                            },
                            "help": {
                                "type": "string",
                                "description": "Help text describing the setting"
                            },
                            "default": {
                                "description": "Default value for the setting",
                                "oneOf": [
                                    {
                                        "type": "string"
                                    },
                                    {
                                        "type": "integer"
                                    },
                                    {
                                        "type": "boolean"
                                    }
                                ]
                            }
                        },
                        "additionalProperties": false
                    }
                },
                "additionalProperties": false
            }
        },
        "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sampleConfig": {
      "type": "object",
      "description": "Shared sample configuration properties for patterns and library methods",
      "properties": {
        "description": {
          "type": "string",
          "description": "Human-readable description"
        },
        "sample_type": {
          "type": "string",
          "description": "The sample type classification (e.g., 10X_SINGLE, 10X_DUAL, SMARTSEQ, IDT_UMI, NOINDEX, ordinary)",
          "pattern": "^[A-Z0-9_]+$"
        },
        "index_length": {
          "type": "array",
          "description": "Array of [i7_length, i5_length] for index lengths",
          "items": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 0
              },
              {
                "type": "string",
                "enum": ["calculated"]
              }
            ]
          },
          "minItems": 2,
          "maxItems": 2
        },
        "umi_config": {
          "oneOf": [
            {
              "type": "null",
              "description": "No UMI present"
            },
            {
              "type": "object",
              "description": "UMI configuration for each read component",
              "properties": {
                "i7": {
                  "$ref": "#/$defs/umiComponent"
                },
                "i5": {
                  "$ref": "#/$defs/umiComponent"
                },
                "R1": {
                  "$ref": "#/$defs/umiComponent"
                },
                "R2": {
                  "$ref": "#/$defs/umiComponent"
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "calculate_lengths": {
          "type": "boolean",
          "description": "Whether to calculate index/UMI lengths dynamically from the sample data"
        },
        "named_indices": {
          "type": "string",
          "description": "Name of the named indices file (without .csv extension) to use for expanding this configuration"
        },
        "BCLConvert_Settings": {
            "type": "object",
            "description": "Override BCL Convert global settings for this pattern/library method. Keys are setting names (e.g., TrimUMI, CreateFastqForIndexReads), values are booleans, integers, or strings matching the setting type.",
            "patternProperties": {
                ".*": {
                    "oneOf": [
                        {
                            "type": "boolean"
                        },
                        {
                            "type": "integer"
                        },
                        {
                            "type": "string"
                        }
                    ]
                }
            },
            "additionalProperties": false
        },
        "conditional_rules": {
          "$ref": "#/$defs/conditionalRules"
        }
      }
    },
    "umiComponent": {
      "type": "object",
      "description": "UMI configuration for a single read component (i7, i5, R1, or R2)",
      "required": ["position", "length"],
      "properties": {
        "position": {
          "type": "string",
          "description": "Position of the UMI in the read",
          "enum": ["start", "end"]
        },
        "length": {
          "oneOf": [
            {
              "type": "integer",
              "description": "Fixed UMI length in base pairs",
              "minimum": 0
            },
            {
              "type": "string",
              "description": "Dynamically calculated UMI length",
              "enum": ["calculated"]
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "conditionalRules": {
      "type": "object",
      "description": "Conditional rules for BCLConvert settings that apply based on sample properties",
      "patternProperties": {
        "^[A-Za-z0-9_]+$": {
          "type": "array",
          "description": "List of rules for a specific BCLConvert setting",
          "items": {
            "type": "object",
            "required": ["name", "conditions", "action"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique identifier for this rule"
              },
              "description": {
                "type": "string",
                "description": "Human-readable explanation of what this rule does"
              },
              "conditions": {
                "type": "object",
                "description": "Condition logic to evaluate (supports all_of, any_of, or direct condition)",
                "additionalProperties": true
              },
              "action": {
                "type": "string",
                "description": "Action to take when condition matches",
                "enum": ["set_value"]
              },
              "value": {
                "description": "Value to set when condition matches (can be boolean, integer, string, or EXCLUDE)",
                "oneOf": [
                  {"type": "boolean"},
                  {"type": "integer"},
                  {"type": "string"}
                ]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
